    public void addProduct(Product product) {
        inventory.add(product);
        System.out.printf("%s was added to inventory.", product.name);
    }

    public void removeProduct(String name, int amount) {

        if (inventory.isEmpty()) {
            System.out.println("No products in inventory.");
            return;
        }

        if (amount <= 0) {
            System.out.println("Amount to remove must be greater than 0.");
            return;
        }

        for (int i = 0; i < inventory.size(); i++) {

            Product product = inventory.get(i);

            if (product.name.equalsIgnoreCase(name)) {

                if (amount > product.quantity) {
                    System.out.printf("You tried to remove %d, but only %d exist.%n",
                            amount, product.quantity);
                    return;
                }

                product.quantity -= amount;
                System.out.printf("Removed %d of %s.%n",
                        amount, product.name);

                // If stock reaches 0, remove product entirely
                if (product.quantity == 0) {
                    inventory.remove(i);
                    System.out.printf("%s has 0 stock and was removed from inventory.%n",
                            product.name);
                }

                return;
            }
        }

        System.out.printf("Product named \"%s\" was not found.%n", name);
    }

    public void viewInventory() {
        if (inventory.isEmpty()) {
            System.out.println("No products in inventory.");
            return;
        }

        System.out.println("\n--- CURRENT INVENTORY ---");
        for (Product product : inventory) {
            printProductDetails(product);
        }
    }

    //Polymorphism used in printing details
    private void printProductDetails(Product product) {
        System.out.printf(
                "Item ID: %d%n" +
                        "Name: %s%n" +
                        "Category: %s%n" +
                        "Price: $%.2f%n" +
                        "Quantity: %d%n",
                product.itemID,
                product.name,
                product.category,
                product.price,   // if price is stored as cents (int)
                product.quantity
        );

        // Show extra info depending on what kind of product it is
        if (product instanceof BrandedItem) {
            BrandedItem branded = (BrandedItem) product;
            System.out.printf(
                    "Brand: %s%n" + "Manufacturer: %s%n", branded.getBrandName(), branded.getManufacturerName());
        } else if (product instanceof GenericItem) {
            GenericItem generic = (GenericItem) product;
            System.out.printf("Store Label: %s%n", generic.getStoreLabelInformation());
        }

        System.out.println("-----------------------------------");
    }

    public void viewStats() {
        if (inventory.isEmpty()) {
            System.out.println("No products in inventory, so no stats to show.");
            return;
        }

        System.out.println("\n--- PRODUCT INVENTORY STATS ---");

        for (Product product : inventory) {
            System.out.printf(
                    "Name: %s | Item ID: %d | Quantity: %d%n",
                    product.name,
                    product.itemID,
                    product.quantity
